# Copy this file to .env and fill in your real API keys
# DO NOT commit .env to version control!

# --- Ocean.io API (lookalike companies) ---
OCEAN_API_KEY=your_ocean_api_key_here

# --- Prospeo API (decision-makers + LinkedIn URLs) ---
PROSPEO_API_KEY=your_prospeo_api_key_here

# --- Eazyreach API (LinkedIn URL → verified email) ---
EAZYREACH_API_KEY=your_eazyreach_api_key_here

# --- Brevo API (send transactional emails) ---
BREVO_API_KEY=your_brevo_api_key_here

# --- Sender identity (must be a verified sender in Brevo) ---
SENDER_NAME=Your Name
SENDER_EMAIL=you@yourdomain.com

# --- Volume limits (keep demo runs quick and credit-light) ---
MAX_COMPANIES=5
MAX_CONTACTS_PER_COMPANY=2
